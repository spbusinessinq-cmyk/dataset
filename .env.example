# ── RSR Data Hub — Environment Variables ─────────────────────────────────────

# Server port (default: 8080 dev / 3000 Docker)
PORT=3000

# Data persistence directory (absolute path)
DATA_DIR=./data

# ── Ollama LLM (optional) ─────────────────────────────────────────────────────
# If Ollama is unavailable, the system falls back to heuristic analysis.
# To enable Ollama, run: ollama pull llama3.2:3b
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:3b

# ── Session Secret ────────────────────────────────────────────────────────────
SESSION_SECRET=change-me-in-production-use-a-long-random-string
